// firestore.rules
// Deploy with: firebase deploy --only firestore:rules
//
// These rules allow:
//  - Public read of sensor_readings (lock down in production with auth)
//  - Writes ONLY from authenticated server (via Admin SDK, which bypasses rules)
//  - No client-side writes — all data enters through the Node.js API

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /sensor_readings/{docId} {
      // Allow dashboard clients to read readings
      allow read: if true;

      // Block all client-side writes — the Node.js API uses Admin SDK
      // which bypasses these rules entirely. Direct client writes are rejected.
      allow write: if false;
    }

    // Deny access to all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
